DEPLOY_PATH=/opt/awardsferm

# Порты на хосте (за системным nginx или напрямую)
FRONTEND_PORT=55504
API_PORT=55503

# Обязательно: секрет JWT (минимум 32 символа). Сгенерировать: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48

# Браузер в Worker: true = headless (рекомендуется на Linux VPS)
BROWSER_HEADLESS=true

# OAuth-токен РСЯ (опционально). Можно также profiles/rsya-token.txt на сервере.
# RSYA_OAUTH_TOKEN=

# Пусто = same-origin: браузер ходит на /api через nginx фронта.
# VITE_API_URL=
